# Prisma / PostgreSQL (Supabase)
# Runtime connection — Transaction pooler (port 6543) for Next.js serverless functions
DATABASE_URL="postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# CLI connection — Direct connection (port 5432) for prisma db push / prisma migrate
# Note: URL-encode special chars in password (@ → %40, & → %26, etc.)
DIRECT_URL="postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-[REGION].pooler.supabase.com:5432/postgres"

# Supabase Auth & Storage (public — safe for client-side)
NEXT_PUBLIC_SUPABASE_URL="https://[YOUR-PROJECT-REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="[YOUR-ANON-KEY]"

# Supabase Service Role key (secret — used for admin auth verification)
SUPABASE_SERVICE_ROLE_KEY="[YOUR-SERVICE-ROLE-KEY]"

# Site URL (used for SEO — sitemap, canonical URLs, OpenGraph, etc.)
NEXT_PUBLIC_SITE_URL="https://mdmevents.org"

# Resend (email notifications)
RESEND_API_KEY="re_xxxxxxxxxx"
ADMIN_EMAIL="admin@mdmevents.org"
