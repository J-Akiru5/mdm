generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Portfolio {
  id                String           @id @default(uuid())
  title             String
  category          String
  imageUrl          String           @map("image_url")
  clientLogo        String?          @map("client_logo")
  clientName        String?          @map("client_name")
  challenge         String?          @map("challenge")
  solution          String?          @map("solution")
  result            String?          @map("result")
  highlight         Boolean          @default(false)
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @default(now()) @updatedAt @map("updated_at")
  updatedByUserId   String?          @map("updated_by_user_id")
  updatedByEmail    String?          @map("updated_by_email")
  images            PortfolioImage[]

  @@map("portfolio")
}

model PortfolioImage {
  id          String    @id @default(uuid())
  portfolioId String    @map("portfolio_id")
  url         String
  sortOrder   Int       @default(0) @map("sort_order")
  createdAt   DateTime  @default(now()) @map("created_at")
  portfolio   Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  @@map("portfolio_images")
}

model ContactSubmission {
  id        String   @id @default(uuid())
  fullName  String   @map("full_name")
  email     String
  phone     String?
  company   String?
  eventType String?  @map("event_type")
  eventDate String?  @map("event_date")
  message   String
  createdAt DateTime @default(now()) @map("created_at")

  @@map("contact_submissions")
}

model Category {
  id              String   @id @default(uuid())
  name            String   @unique
  sortOrder       Int      @default(0) @map("sort_order")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at")
  updatedByUserId String?  @map("updated_by_user_id")
  updatedByEmail  String?  @map("updated_by_email")

  @@map("categories")
}

model Feedback {
  id        String   @id @default(uuid())
  name      String
  email     String
  rating    Int
  comment   String
  createdAt DateTime @default(now()) @map("created_at")

  @@map("feedbacks")
}

model AuditLog {
  id          String   @id @default(uuid())
  createdAt   DateTime @default(now()) @map("created_at")
  action      String   // LOGIN | LOGIN_FAILED | LOGOUT | CREATE | UPDATE | DELETE
  entity      String   // Portfolio | Category | Auth | ContactSubmission | Feedback
  entityId    String?  @map("entity_id")
  actorId     String?  @map("actor_id")
  actorEmail  String?  @map("actor_email")
  ipAddress   String?  @map("ip_address")
  userAgent   String?  @map("user_agent")
  before      Json?
  after       Json?
  metadata    Json?    // e.g. { title: "My Event" } for display label

  @@index([action])
  @@index([entity])
  @@index([actorEmail])
  @@index([createdAt])
  @@map("audit_logs")
}

model NotificationRecipient {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  active    Boolean  @default(true)
  types     String[] @default(["inquiry", "feedback"])
  createdAt DateTime @default(now()) @map("created_at")

  @@map("notification_recipients")
}

